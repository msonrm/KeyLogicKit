        "J+V": "・", "K+V": "…", "L+V": "／", "V+semicolon": "《》",
        "V+comma": "，", "V+dot": "．",

        "_comment_pa": "ぱ行 [B]",
        "B+H": "ぺ", "B+J": "ぽ", "B+K": "ぷ", "B+L": "ぴ", "B+semicolon": "ぱ",
        "B+U": "ぴょ", "B+I": "ぴゅ", "B+O": "ぴゃ",
        "B+N": "ぺん", "B+M": "ぽん", "B+comma": "ぷん", "B+dot": "ぴん", "B+slash": "ぱん",

        "_comment_small": "捨て仮名・旧かな [Q]",
