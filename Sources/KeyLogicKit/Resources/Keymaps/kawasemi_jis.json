        "E+Y": "じぇ", "E+U": "じょ", "E+I": "じゅ", "E+O": "じゃ",
        "E+N": "ぜん", "E+M": "ぞん", "E+comma": "ずん", "E+dot": "じん", "E+slash": "ざん",

