        "Q+Y": "ヶ", "Q+U": "ょ", "I+Q": "ゅ", "O+Q": "ゃ", "P+Q": "ゎ",
        "N+Q": "ゑ", "Q+comma": "，", "Q+dot": "．", "Q+slash": "ヵ",

        "_comment_ga": "が行 [W]",
        "H+W": "げ", "J+W": "ご", "K+W": "ぐ", "L+W": "ぎ", "W+semicolon": "が",
        "W+Y": "ぐぇ", "U+W": "ぎょ", "I+W": "ぎゅ", "O+W": "ぎゃ",
        "N+W": "げん", "M+W": "ごん", "W+comma": "ぐん", "W+dot": "ぎん", "W+slash": "がん",

        "_comment_za": "ざ行 [E]",
