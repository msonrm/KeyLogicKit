{
  "formatVersion": "1.0",
  "name": "かわせみ配列(JIS)",
  "author": "semialt",
  "description": "左手で行（か・さ・た行等）を指定し右手で段（あ・い・う・え・お）を指定して同時押しするかな配列。50音表の行列構造を直接キー配置に対応させた覚えやすい同時打鍵方式（JIS キーボード）。",
  "license": "CC-BY-4.0",
  "keyboardLayout": "jis",
  "targetScript": "hiragana",
  "modeKeys": {
    "lang2": "switchToEnglish",
    "lang1": "switchToJapanese",
    "ctrl+space": "toggleInputMode",
    "ctrl+shift+j": "switchToJapanese",
    "ctrl+shift+semicolon": "switchToEnglish"
  },
  "behavior": {
    "type": "chord",
    "config": {
      "hidToKey": {
        "q": "Q", "w": "W", "e": "E", "r": "R", "t": "T",
        "y": "Y", "u": "U", "i": "I", "o": "O", "p": "P",
        "a": "A", "s": "S", "d": "D", "f": "F", "g": "G",
        "h": "H", "j": "J", "k": "K", "l": "L", "semicolon": "semicolon",
        "z": "Z", "x": "X", "c": "C", "v": "V", "b": "B",
        "n": "N", "m": "M", "comma": "comma", "period": "dot", "slash": "slash"
      },
      "shiftKeys": [],
      "simultaneousWindow": 0.1,
      "lookupTable": {
        "_comment_single": "単打",
        "Q": "に", "W": "が", "E": "じ", "R": "で", "T": "ば",
        "Y": "れ", "U": "よ", "I": "ゆ", "O": "や", "P": "を",
        "A": "の", "S": "か", "D": "し", "F": "と", "G": "は",
        "H": "え", "J": "お", "K": "う", "L": "い", "semicolon": "あ",
        "Z": "な", "X": "る", "C": "ま", "V": "て", "B": "わ",
        "N": "っ", "M": "ん", "comma": "，", "dot": "．", "slash": "－",

        "_comment_na": "な行 [A]",
        "A+H": "ね", "A+J": "の", "A+K": "ぬ", "A+L": "に", "A+semicolon": "な",
        "A+U": "にょ", "A+I": "にゅ", "A+O": "にゃ",
        "A+N": "ねん", "A+M": "のん", "A+comma": "ぬん", "A+dot": "にん", "A+slash": "なん",

        "_comment_ka": "か行 [S]",
        "H+S": "け", "J+S": "こ", "K+S": "く", "L+S": "き", "S+semicolon": "か",
        "S+Y": "くぇ", "S+U": "きょ", "I+S": "きゅ", "O+S": "きゃ", "P+S": "くぁ",
        "N+S": "けん", "M+S": "こん", "S+comma": "くん", "S+dot": "きん", "S+slash": "かん",

        "_comment_sa": "さ行 [D]",
