        "T+Y": "ヴェ", "T+U": "びょ", "I+T": "びゅ", "O+T": "びゃ", "P+T": "ヴァ",
        "N+T": "べん", "M+T": "ぼん", "T+comma": "ぶん", "T+dot": "びん", "T+slash": "ばん"
