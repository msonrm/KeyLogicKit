        "D+Y": "しぇ", "D+U": "しょ", "D+I": "しゅ", "D+O": "しゃ",
        "D+N": "せん", "D+M": "そん", "D+comma": "すん", "D+dot": "しん", "D+slash": "さん",

        "_comment_ta": "た行 [F]",
        "F+H": "て", "F+J": "と", "F+K": "つ", "F+L": "ち", "F+semicolon": "た",
        "F+Y": "ちぇ", "F+U": "ちょ", "F+I": "ちゅ", "F+O": "ちゃ", "F+P": "つぁ",
