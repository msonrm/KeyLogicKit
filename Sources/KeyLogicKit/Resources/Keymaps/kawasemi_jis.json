        "R+Y": "ぢぇ", "R+U": "ぢょ", "I+R": "でゅ", "O+R": "ぢゃ",
        "N+R": "でん", "M+R": "どん", "R+comma": "づん", "R+dot": "ぢん", "R+slash": "だん",

