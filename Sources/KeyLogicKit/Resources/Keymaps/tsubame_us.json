{
  "formatVersion": "1.0",
  "name": "つばめ配列(US)",
  "author": "mikado",
  "description": "つばめ配列 2.0 行段系逐次入力（US キーボード）。ホームポジション10キーで50音を入力。交互打鍵＝清音、同手打鍵＝濁音。",
  "keyboardLayout": "us",
  "targetScript": "hiragana",
  "behavior": {
    "type": "sequential",
    "characterMap": {
      "0": "０", "1": "１", "2": "２", "3": "３", "4": "４",
      "5": "５", "6": "６", "7": "７", "8": "８", "9": "９",
      "[": "「", "]": "」", "{": "『", "}": "』",
      "(": "（", ")": "）", "<": "＜", ">": "＞",
      "-": "ー", "~": "〜", "^": "＾", "_": "＿",
      "\"": "\u201d", "'": "\u2019", "`": "｀",
      "+": "＋", "=": "＝", "*": "＊",
      "!": "！", "?": "？", ":": "：",
      "@": "＠", "#": "＃", "$": "＄", "%": "％",
      "&": "＆", "|": "｜", "\\": "＼", "¥": "￥"
    }
  },
  "modeKeys": {
    "ctrl+space": "toggleInputMode",
    "ctrl+shift+j": "switchToJapanese",
    "ctrl+shift+semicolon": "switchToEnglish"
  },
  "prefixShiftKeys": ["a", "s", "d", "f", "g", "h", "j", "k", "l", ";"],
  "inputMappings": {
    "_comment_upper_single": "単打（上段ショートカット）",
    "q": "ー",
    "w": "の",
    "e": "か",
    "r": "た",
    "t": "す",
    "y": "ろ",
    "u": "う",
    "i": "い",
    "o": "し",
    "p": "を",

    "_comment_lower_single": "単打（下段ショートカット）",
    "z": "あ",
    "x": "お",
    "c": "え",
    "v": "な",
    "b": "さ",
    "n": "ん",
    "m": "っ",
    ",": "、",
    ".": "。",

    "_comment_ka": "か行 K＝1打目（交互=清音、同手=濁音）",
    "ka": "か",
    "kd": "き",
    "kf": "く",
    "kg": "け",
    "ke": "け",
    "ks": "こ",
    "kq": "きゃ",
    "kr": "きゅ",
    "kw": "きょ",
    "k;": "が",
    "kk": "ぎ",
    "kj": "ぐ",
    "kh": "げ",
